# PostgreSQL (recommended with docker compose up -d):
# DATABASE_URL=postgresql+psycopg://flowcast:flowcast@localhost:5432/flowcast
# SQLite fallback for quick local dev:
DATABASE_URL=sqlite:///./flowcast.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEFAULT_ACCOUNT_ID=acct_main
BALANCE_THRESHOLD_USD=2000

# Plaid (https://dashboard.plaid.com) — required for bank statement onboarding
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_sandbox_secret
PLAID_ENV=sandbox
